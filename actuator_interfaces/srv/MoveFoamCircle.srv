# Radius of the circle in degrees of string travel
float32 radius
# Number of discrete steps to divide the circle into (0 = default 36)
int32 steps
# Pause between each step in seconds (0.0 = no pause)
float32 step_delay
# True = clockwise when viewed from above, False = counter-clockwise
bool clockwise
# Optional CSV label override (empty = auto-generate)
string label
---
bool success
string message
